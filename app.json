{
  "expo": {
    "name": "Temani",
    "slug": "temani",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logotemani.png",
    "scheme": "temani",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/logotemani.png"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/logotemani.png",
        "backgroundImage": "./assets/images/logotemani.png",
        "monochromeImage": "./assets/images/logotemani.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.tianarsamm.temani"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logotemani.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/logotemani.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/logotemani.png",
          "color": "#2D6A4F",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "25c913c2-65f9-453c-a14c-a2060456fbea"
      }
    },
    "owner": "tianarsamm"
  }
}
